benchmark_*.txt

# Test results (exclude test run artifacts, but keep generated source files for inspection)
/Test/TestResults/*.trx
/Test/TestResults/*.xml
/Test/TestResults/*.coverage

# NuGet packages (don't commit built packages)
/nupkg/

# Visual Studio
/.vs/
**/.vs/
/OSSRequestForm-v4.xlsx

# IDE and tool settings
/.vscode/
/.claude/
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
