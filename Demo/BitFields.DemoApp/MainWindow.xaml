<Window x:Class="BitFields.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stardust BitFields Playground" Height="820" Width="1200">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="RFC Diagram">
                <ScrollViewer x:Name="RfcScroller" VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=RfcScroller}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="40" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16,16,16,0" Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="RFC-Style Bit Field Diagrams" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                <TextBlock Text="  —  Generated from struct metadata via BitFieldDiagram.Render() and RenderList()" VerticalAlignment="Center" Opacity="0.6" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Open .NET Assembly&#x2026;" Padding="12,4" Click="OnOpenAssemblyForRfc" />
                                <Button x:Name="RfcResetButton" Content="Reset to Demo Structs" Padding="12,4" Margin="8,0,0,0" Click="OnResetRfcStructs" Visibility="Collapsed" />
                                <TextBlock x:Name="RfcAssemblyStatus" Margin="12,0,0,0" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Struct:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="RfcStructPicker" Width="220" SelectionChanged="OnRfcStructChanged" />
                                <TextBlock Text="Bits/Row:" VerticalAlignment="Center" Margin="16,0,8,0" />
                                <ComboBox x:Name="RfcBitsPerRow" Width="70" SelectionChanged="OnRfcStructChanged" />
                                <Button Content="Copy to Clipboard" Padding="12,4" Margin="16,0,0,0" Click="OnCopyRfcDiagram" />
                                <TextBlock Text="Comment:" VerticalAlignment="Center" Margin="16,0,8,0" />
                                <ComboBox x:Name="RfcCommentStyle" Width="120" SelectionChanged="OnRfcStructChanged" />
                                <CheckBox x:Name="RfcShowDescriptions" Content="Show Descriptions" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0" Checked="OnRfcStructChanged" Unchecked="OnRfcStructChanged" />
                                <CheckBox x:Name="RfcShowByteOffset" Content="Show Byte Offset" VerticalAlignment="Center" Margin="16,0,0,0" IsChecked="False" Checked="OnRfcStructChanged" Unchecked="OnRfcStructChanged" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="&#x25B8; Diagram" FontWeight="Bold" FontSize="13" Margin="16,16,16,6" Foreground="#FF38BDF8" />
                        <TextBox Grid.Row="2" x:Name="RfcDiagramOutput" Margin="16,0,16,16" Padding="8,4" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="PE Viewer">
                <ScrollViewer x:Name="PeScroller" VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=PeScroller}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="40" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16,16,16,0" Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="OpenPeButton" Content="Open PE File" Padding="12,6" Click="OnOpenPeFile" />
                                <TextBlock x:Name="PeFilePath" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>

                            <TextBlock Text="&#x25B8; Fields" FontWeight="Bold" FontSize="13" Margin="0,16,0,6" Foreground="#FF38BDF8" />
                            <WrapPanel x:Name="PeFieldSummaryPanel" />

                            <TextBlock Text="&#x25B8; Header Hex" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="PeHexBytesPanel" />
                            </Border>

                            <TextBlock Text="&#x25B8; Header Binary" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="PeBinaryBitsPanel" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="&#x25B8; Raw Bytes" FontWeight="Bold" FontSize="13" Margin="16,16,16,6" Foreground="#FF38BDF8" />
                        <TextBox Grid.Row="2" x:Name="PeRawBytes" Margin="16,0,16,16" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" IsReadOnly="True" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Network Packet Viewer">
                <ScrollViewer x:Name="NetScroller" VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=NetScroller}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="40" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16,16,16,0" Orientation="Vertical">
                            <TextBlock Text="Paste IPv4/TCP packet bytes (hex, spaces allowed):" />
                            <TextBox x:Name="PacketHexInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" TextChanged="OnPacketHexInputChanged" />

                            <TextBlock Text="&#x25B8; Fields" FontWeight="Bold" FontSize="13" Margin="0,16,0,6" Foreground="#FF38BDF8" />
                            <WrapPanel x:Name="FieldSummaryPanel" />

                            <TextBlock Text="&#x25B8; Hex" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="HexBytesPanel" />
                            </Border>

                            <TextBlock Text="&#x25B8; Binary" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="BinaryBitsPanel" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="&#x25B8; HTTP Payload" FontWeight="Bold" FontSize="13" Margin="16,16,16,6" Foreground="#FF38BDF8" />
                        <TextBox Grid.Row="2" x:Name="HttpPayload" Margin="16,0,16,16" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" IsReadOnly="True" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="CPU Register Lab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" Orientation="Vertical">
                        <TextBlock Text="Status Register (16-bit)" FontSize="16" FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Raw Hex" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="CpuRawHex" Width="100" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Consolas" FontSize="14" Padding="4,2" TextChanged="OnCpuRawHexChanged" />
                        </StackPanel>
                        <WrapPanel Margin="0,8,0,0" ItemHeight="30" ItemWidth="140">
                            <CheckBox x:Name="FlagCarry" Content="Carry" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                            <CheckBox x:Name="FlagZero" Content="Zero" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                            <CheckBox x:Name="FlagInterrupt" Content="Interrupt" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                            <CheckBox x:Name="FlagDecimal" Content="Decimal" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                            <CheckBox x:Name="FlagOverflow" Content="Overflow" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                            <CheckBox x:Name="FlagNegative" Content="Negative" Checked="OnCpuFlagChanged" Unchecked="OnCpuFlagChanged" />
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Mode" VerticalAlignment="Center" />
                            <Slider x:Name="CpuMode" Minimum="0" Maximum="7" Width="200" ValueChanged="OnCpuModeChanged" />
                            <TextBlock x:Name="CpuModeValue" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="&#x25B8; Fields" FontWeight="Bold" FontSize="13" Margin="0,16,0,6" Foreground="#FF38BDF8" />
                        <WrapPanel x:Name="CpuFieldSummaryPanel" />

                        <TextBlock Text="&#x25B8; Hex" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                            <WrapPanel x:Name="CpuHexBytesPanel" />
                        </Border>

                        <TextBlock Text="&#x25B8; Binary" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                            <WrapPanel x:Name="CpuBinaryBitsPanel" />
                        </Border>

                        <TextBlock Text="Mixed Endian Demo" FontWeight="Bold" Margin="0,12,0,4" />
                        <TextBlock x:Name="MixedEndianSummary" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="🛰️ FP Stream Lab">
                <ScrollViewer x:Name="FpScroller" VerticalScrollBarVisibility="Auto">
                    <Grid MinHeight="{Binding ViewportHeight, ElementName=FpScroller}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="40" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16,16,16,0" Orientation="Vertical">
                            <TextBlock Text="Composable Floating-Point Stream Lab" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Single TelemetryFrame struct with dual IEEE 754 / native access — bit-shifted to any stream offset" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0" />
                            <TextBlock x:Name="FpStructDesc" TextWrapping="Wrap" Margin="0,4,0,0" FontSize="11" Opacity="0.7" Visibility="Collapsed" />

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="Stream Start Bit:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Slider x:Name="FpOffsetSlider" Minimum="0" Maximum="7" Width="200" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="OnFpOffsetChanged" />
                                <Border x:Name="FpOffsetBadge" CornerRadius="14" Width="28" Height="28" Margin="8,0,0,0">
                                    <TextBlock x:Name="FpOffsetValue" Text="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold" Foreground="White" />
                                </Border>
                                <TextBlock x:Name="FpStreamInfo" VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Consolas" FontSize="11" Opacity="0.6" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Temperature (°C):" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox x:Name="FpTemperature" Width="120" Height="26" FontFamily="Consolas" FontSize="13" Padding="4,2" VerticalContentAlignment="Center" Text="23.456" TextChanged="OnFpValueChanged" />
                                <TextBlock Text="Pressure (hPa):" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox x:Name="FpPressure" Width="120" Height="26" FontFamily="Consolas" FontSize="13" Padding="4,2" VerticalContentAlignment="Center" Text="1013.25" TextChanged="OnFpValueChanged" />
                                <TextBlock Text="Health:" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox x:Name="FpHealth" Width="80" Height="26" FontFamily="Consolas" FontSize="13" Padding="4,2" VerticalContentAlignment="Center" Text="0.98" TextChanged="OnFpValueChanged" />
                                <TextBlock Text="Humidity (%):" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox x:Name="FpHumidity" Width="80" Height="26" FontFamily="Consolas" FontSize="13" Padding="4,2" VerticalContentAlignment="Center" Text="0.65" TextChanged="OnFpValueChanged" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="▶ Simulate Stream (10)" Padding="12,4" Click="OnFpSimulate" />
                                <Button Content="↺ Reset" Padding="12,4" Margin="8,0,0,0" Click="OnFpReset" />
                            </StackPanel>

                            <TextBlock Text="&#x25B8; Bit-Shift Round-Trip" FontWeight="Bold" FontSize="13" Margin="0,16,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <WrapPanel x:Name="FpRoundTripPanel" Orientation="Horizontal" />
                            </Border>

                            <TextBlock Text="&#x25B8; Written &#x2192; Read Back" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <DataGrid x:Name="FpVerifyGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserSortColumns="False" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal" SelectionMode="Single"
                                      Margin="0,0,0,8" FontFamily="Consolas" FontSize="12" RowHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="*" />
                                    <DataGridTextColumn Header="Written" Binding="{Binding Written}" Width="*" />
                                    <DataGridTextColumn Header="Read Back" Binding="{Binding ReadBack}" Width="*" />
                                    <DataGridTextColumn Header="Match" Binding="{Binding Match}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="&#x25B8; Fields" FontWeight="Bold" FontSize="13" Margin="0,16,0,6" Foreground="#FF38BDF8" />
                            <WrapPanel x:Name="FpFieldSummaryPanel" />

                            <TextBlock Text="&#x25B8; Stream Buffer (hex)" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="FpHexBytesPanel" />
                            </Border>

                            <TextBlock Text="&#x25B8; Stream Binary" FontWeight="Bold" FontSize="13" Margin="0,12,0,6" Foreground="#FF38BDF8" />
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10,8">
                                <WrapPanel x:Name="FpBinaryBitsPanel" />
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="16,16,16,16">
                            <TextBlock Text="&#x25B8; RFC Diagram" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#FF38BDF8" />
                            <TextBox x:Name="FpRfcDiagram" TextWrapping="NoWrap" AcceptsReturn="True" IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" Height="180" Margin="0,0,0,12" />
                            <TextBlock Text="&#x25B8; Simulated Stream Log" FontWeight="Bold" FontSize="13" Margin="0,0,0,6" Foreground="#FF7AC04A" />
                            <TextBox x:Name="FpStreamLog" TextWrapping="NoWrap" AcceptsReturn="True" IsReadOnly="True" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" Height="200" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>


        </TabControl>
    </Grid>
</Window>
