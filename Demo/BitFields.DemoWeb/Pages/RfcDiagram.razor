@page "/"
@using BitFields.DemoApp
@inject IJSRuntime JS

<h2 class="page-title">RFC-Style Bit Field Diagrams</h2>
<p class="page-subtitle">Generated from struct metadata via BitFieldDiagram.Render() and RenderList()</p>

<div class="toolbar">
    <label>Struct:</label>
    <select @bind="_selectedIndex" @bind:after="UpdateDiagram">
        @for (int i = 0; i < _sources.Length; i++)
        {
            <option value="@i">@_sources[i].Label</option>
        }
    </select>

    <label>Bits/Row:</label>
    <select @bind="_bitsPerRow" @bind:after="UpdateDiagram">
        <option value="8">8</option>
        <option value="16">16</option>
        <option value="32">32</option>
        <option value="64">64</option>
    </select>

    <label>Comment:</label>
    <select @bind="_commentStyle" @bind:after="UpdateDiagram">
        <option value="0">None</option>
        <option value="1">* (asterisk)</option>
        <option value="2">// (double-slash)</option>
        <option value="3">/// (triple-slash)</option>
    </select>

    <label><input type="checkbox" @bind="_showDescriptions" @bind:after="UpdateDiagram" /> Descriptions</label>
    <label><input type="checkbox" @bind="_showByteOffset" @bind:after="UpdateDiagram" /> Byte Offset</label>

    <button @onclick="CopyToClipboard">Copy to Clipboard</button>
    @if (_copied)
    {
        <span style="color: var(--accent); font-size: 0.8rem;">Copied!</span>
    }
</div>

<div class="toolbar" style="margin-top: 4px;">
    <label>Open .NET Assembly:</label>
    <InputFile OnChange="OnAssemblySelected" accept=".dll,.exe" />
    @if (_assemblyStatus != null)
    {
        <span style="font-size: 0.8rem; color: var(--muted);">@_assemblyStatus</span>
    }
    @if (_hasLoadedAssembly)
    {
        <button @onclick="RefreshFile">Refresh</button>
        <button @onclick="ResetToBuiltIn">Reset to Built-in</button>
    }
</div>

<div class="section-header">&#x25B8; Diagram</div>
<div class="diagram-output">@_diagramText</div>

@code {
    #pragma warning disable CS0618 // DiagramSection: retained until DemoWeb migrates to Type-based API
    private record struct DiagramSource(string Label, DiagramSection[] Sections);

    private DiagramSource[] _sources = [];
    private DiagramSource[] _builtInSources = [];
    private int _selectedIndex;
    private int _bitsPerRow = 32;
    private int _commentStyle;
    private bool _showDescriptions;
    private bool _showByteOffset;
    private string _diagramText = "";
    private bool _copied;
    private string? _assemblyStatus;
    private bool _hasLoadedAssembly;
    private IBrowserFile? _assemblyFile;

    private static DiagramSource Single(string label, BitFieldInfo[] fields) =>
        new(label, [new("", fields)]);

    protected override void OnInitialized()
    {
        _builtInSources =
        [
            Single("IPv4 Header", IPv4HeaderView.Fields.ToArray()),
            Single("TCP Header", TcpHeaderView.Fields.ToArray()),
            Single("DOS Header", DosHeaderView.Fields.ToArray()),
            Single("COFF Header", CoffHeaderView.Fields.ToArray()),
            Single("Optional Header", OptionalHeaderView.Fields.ToArray()),
            Single("CPU Status Register", CpuStatusRegister.Fields.ToArray()),
            new("68020 Register Set",
            [
                new("── Data Registers ──", M68020DataRegisters.Fields.ToArray()),
                new("── Address Registers ──", M68020AddressRegisters.Fields.ToArray()),
                new("PC", M68020PC.Fields.ToArray()),
                new("SR", M68020SR.Fields.ToArray()),
                new("CCR", M68020CCR.Fields.ToArray()),
                new("USP", M68020USP.Fields.ToArray()),
                new("ISP", M68020ISP.Fields.ToArray()),
                new("MSP", M68020MSP.Fields.ToArray()),
                new("VBR", M68020VBR.Fields.ToArray()),
                new("SFC", M68020SFC.Fields.ToArray()),
                new("DFC", M68020DFC.Fields.ToArray()),
                new("CACR", M68020CACR.Fields.ToArray()),
                new("CAAR", M68020CAAR.Fields.ToArray()),
            ]),
    ];
        _sources = _builtInSources;
        UpdateDiagram();
    }

    private void UpdateDiagram()
    {
        if (_selectedIndex < 0 || _selectedIndex >= _sources.Length) return;
        var source = _sources[_selectedIndex];
        string? commentPrefix = _commentStyle switch
        {
            1 => "* ",
            2 => "// ",
            3 => "/// ",
            _ => null
        };
        _diagramText = BitFieldDiagram.RenderListToString(
            source.Sections, _bitsPerRow, _showDescriptions, _showByteOffset, commentPrefix);
    }
#pragma warning restore CS0618

    private async Task OnAssemblySelected(InputFileChangeEventArgs e)
    {
        _assemblyStatus = null;

        try
        {
            if ((await LoadAssembly(e.File)).IsFailure)
            {
                return;
            }
            UpdateDiagram();
        }
        catch (Exception ex)
        {
            _assemblyStatus = $"Error: {ex.Message}";
        }
    }

    private async Task<Result<string>> LoadAssembly(IBrowserFile file)
    {
        _assemblyStatus = null;
        try
        {
            _hasLoadedAssembly = false;
            _assemblyFile = null;

            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();

            var result = AssemblyStructDiscovery.Discover(bytes, file.Name);

            if (result.Error != null && result.Structs.Count == 0)
            {
                _assemblyStatus = $"{result.AssemblyName}: {result.Error}";
                return Result<string>.Err(_assemblyStatus);
            }

            string? previousSelection = _selectedIndex >= 0 && _selectedIndex < _sources.Length
                ? _sources[_selectedIndex].Label
                : null;

#pragma warning disable CS0618
            var sources = new List<DiagramSource>();
            foreach (var s in result.Structs)
                sources.Add(Single(s.DisplayName, s.Fields));
#pragma warning restore CS0618

            _sources = sources.ToArray();
            _assemblyFile = file;
            _hasLoadedAssembly = true;

            int restoredIndex = -1;
            if (previousSelection != null)
            {
                for (int i = 0; i < _sources.Length; i++)
                {
                    if (_sources[i].Label == previousSelection)
                    {
                        restoredIndex = i;
                        break;
                    }
                }
            }
            _selectedIndex = restoredIndex >= 0 ? restoredIndex : 0;

            _assemblyStatus = $"Loaded {result.Structs.Count} struct(s) from {result.AssemblyName}";
            return Result<string>.Ok();
        }
        catch (Exception ex)
        {
            _assemblyStatus = $"Error: {ex.Message}";   
            return Result<string>.Err(_assemblyStatus);
        }
    }

    private async Task RefreshFile()
    {
        if (_hasLoadedAssembly && _assemblyFile != null)
        {
            await LoadAssembly(_assemblyFile);
            UpdateDiagram();
        }
    }

    private void ResetToBuiltIn()
    {
        _sources = _builtInSources;
        _selectedIndex = 0;
        _hasLoadedAssembly = false;
        _assemblyStatus = null;
        UpdateDiagram();
    }

    private async Task CopyToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _diagramText);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
        }
        catch
        {
            // Clipboard API may be blocked in some contexts
        }
    }
}
